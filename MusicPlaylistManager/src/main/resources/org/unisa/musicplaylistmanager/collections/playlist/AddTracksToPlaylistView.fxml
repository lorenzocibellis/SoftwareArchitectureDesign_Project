<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="500.0" prefWidth="630.0" stylesheets="@../../css/styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.unisa.musicplaylistmanager.collections.playlist.controller.AddTracksToPlaylistController">
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="70.0" style="-fx-background-color: #F8F8F8; -fx-border-color: #E0E0E0; -fx-border-width: 0 0 1 0;">
            <children>
                <Label text="Aggiungi Tracce">
                    <font>
                        <Font name="System Bold" size="24.0" />
                    </font>
                </Label>
            </children>
            <padding>
                <Insets left="20.0" right="10.0" />
            </padding>
        </HBox>
    </top>
    <center>
        <StackPane>
            <children>
                <ListView fx:id="listView">
                    <placeholder>
                        <Label text="Nessuna traccia disponibile" textFill="#888888">
                            <font>
                                <Font size="16.0" />
                            </font>
                        </Label>
                    </placeholder>
                </ListView>
            </children>
        </StackPane>
    </center>
    <bottom>
        <HBox alignment="CENTER" prefHeight="70.0" spacing="15.0" style="-fx-background-color: white; -fx-border-color: #E0E0E0; -fx-border-width: 1 0 0 0;">
            <children>
                <Button fx:id="confirmButton" mnemonicParsing="false" onAction="#confirmSelection" prefHeight="35.0" prefWidth="120.0" text="✓  Conferma" />
                <Button fx:id="cancelButton" mnemonicParsing="false" onAction="#cancel" prefHeight="35.0" prefWidth="120.0" styleClass="close-button" text="✕  Annulla" />
            </children>
        </HBox>
    </bottom>
</BorderPane>

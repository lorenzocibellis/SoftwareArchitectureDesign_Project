<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane id="AnchorPane" prefHeight="400.0" prefWidth="600.0" style="-fx-background-color: transparent;" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.unisa.musicplaylistmanager.player.PlayerController">
    <children>

        <AnchorPane fx:id="topPane" style="-fx-background-color: #f4f4f4; -fx-border-color: #cccccc; -fx-border-width: 2 0 0 0;" AnchorPane.bottomAnchor="130.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <StackPane AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="50.0">
                    <children>
                        <ImageView fx:id="albumArt" fitHeight="150.0" fitWidth="150.0" pickOnBounds="true" preserveRatio="true" />
                    </children>
                </StackPane>

                <Button fx:id="closeButton" mnemonicParsing="false" onAction="#handleClose" prefHeight="30.0" prefWidth="30.0" style="-fx-background-color: #ff4c4c; -fx-text-fill: white; -fx-background-radius: 15; -fx-cursor: hand;" text="X" AnchorPane.rightAnchor="15.0" AnchorPane.topAnchor="15.0" styleClass="player-action-button">
                    <font><Font name="System Bold" size="14.0" /></font>
                </Button>
                <Button fx:id="minimizeButton" mnemonicParsing="false" onAction="#toggleMinimize" prefHeight="30.0" prefWidth="30.0" style="-fx-background-color: #dddddd; -fx-background-radius: 15; -fx-cursor: hand;" text="v" AnchorPane.rightAnchor="55.0" AnchorPane.topAnchor="15.0" styleClass="player-action-button">
                    <font><Font name="System Bold" size="14.0" /></font>
                </Button>
            </children>
        </AnchorPane>

        <AnchorPane fx:id="bottomPane" prefHeight="130.0" style="-fx-background-color: #f4f4f4; -fx-border-color: #cccccc; -fx-border-width: 1 0 0 0;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
            <children>

                <VBox alignment="CENTER" mouseTransparent="true" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="15.0">
                    <children>
                        <Text fx:id="trackTitle" strokeType="OUTSIDE" strokeWidth="0.0" text="NomeBrano">
                            <font><Font name="System Bold" size="16.0" /></font>
                        </Text>
                        <Text fx:id="authorName" fill="#666666" strokeType="OUTSIDE" strokeWidth="0.0" text="NomeAutore">
                            <font><Font size="13.0" /></font>
                        </Text>
                    </children>
                </VBox>

                <Slider fx:id="songProgress" style="-fx-cursor: hand;" AnchorPane.leftAnchor="144.0" AnchorPane.rightAnchor="144.0" AnchorPane.topAnchor="60.0" />
                <Label fx:id="counter" text="0:00" AnchorPane.leftAnchor="144.0" AnchorPane.topAnchor="75.0" />
                <Label fx:id="duration" text="3:00" AnchorPane.rightAnchor="144.0" AnchorPane.topAnchor="75.0" />

                <HBox alignment="CENTER" spacing="10.0" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
                    <children>
                        <Button fx:id="skipToPreviousButton" mnemonicParsing="false" prefHeight="40.0" prefWidth="40.0" style="-fx-background-color: transparent;" styleClass="player-action-button" />
                        <Button fx:id="executeButton" mnemonicParsing="false" onAction="#handleExecute" prefHeight="40.0" prefWidth="46.0" style="-fx-background-color: transparent; -fx-cursor: hand;" styleClass="player-action-button" />
                        <Button fx:id="skipToNextButton" mnemonicParsing="false" prefHeight="40.0" prefWidth="40.0" style="-fx-background-color: transparent;" styleClass="player-action-button" />
                    </children>
                </HBox>

                <Button fx:id="expandButton" mnemonicParsing="false" onAction="#toggleMinimize" prefHeight="30.0" prefWidth="30.0" style="-fx-background-color: #dddddd; -fx-background-radius: 15; -fx-cursor: hand;" text="^" visible="false" AnchorPane.rightAnchor="55.0" AnchorPane.topAnchor="15.0" styleClass="player-action-button">
                    <font><Font name="System Bold" size="14.0" /></font>
                </Button>
                <Button fx:id="closeButtonMin" mnemonicParsing="false" onAction="#handleClose" prefHeight="30.0" prefWidth="30.0" style="-fx-background-color: #ff4c4c; -fx-text-fill: white; -fx-background-radius: 15; -fx-cursor: hand;" text="X" visible="false" AnchorPane.rightAnchor="15.0" AnchorPane.topAnchor="15.0" styleClass="player-action-button">
                    <font><Font name="System Bold" size="14.0" /></font>
                </Button>

            </children>
        </AnchorPane>

    </children>
</AnchorPane>
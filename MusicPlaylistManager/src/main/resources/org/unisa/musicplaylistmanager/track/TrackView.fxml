<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import java.lang.String?>

<AnchorPane prefHeight="650.0" prefWidth="580.0" stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.unisa.musicplaylistmanager.track.TrackController">
    <children>
        <VBox alignment="TOP_CENTER" prefHeight="650.0" prefWidth="580.0" spacing="20.0" style="-fx-background-color: #F8F8F8;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <children>
                <VBox spacing="10.0">
                    <children>
                        <Label text="Titolo" />
                        <TextField fx:id="titleInput" promptText="Es. Yesterday" />
                        <Label text="Autore" />
                        <TextField fx:id="authorInput" promptText="Es. The Beatles" />
                        <Label text="Anno" />
                        <TextField fx:id="yearInput" promptText="Es. 1965" />
                        <Label text="Genere" />
                        <TextField fx:id="genreInput" promptText="Es. Pop" />
                        <Label text="Durata" />
                        <HBox alignment="CENTER_LEFT" spacing="5.0">
                            <children>
                                <TextField fx:id="minutesInput" prefWidth="70.0" promptText="Minuti" />
                                <Label text=":" />
                                <TextField fx:id="secondsInput" prefWidth="70.0" promptText="Secondi" />
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <VBox spacing="5.0">
                    <children>
                        <Label text="Copertina (Opzionale)" textFill="#555555" />
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                                <TextField fx:id="coverPathInput" editable="false" promptText="Nessun file selezionato" HBox.hgrow="ALWAYS" />
                                <Button fx:id="browseCoverButton" mnemonicParsing="false" onAction="#browseCover" text="Sfoglia..." />
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <VBox spacing="8.0" styleClass="tag-section">
                    <children>
                        <Label text="Tag" styleClass="tag-section-title" />
                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="6.0" styleClass="tag-toggle-card">
                                    <children>
                                        <RadioButton fx:id="favouriteRadio" mnemonicParsing="false" text="Preferita" />
                                        <Label fx:id="favouritePreview" text="♥" visible="false" managed="false">
                                            <styleClass><String fx:value="tag-badge" /><String fx:value="tag-favourite" /></styleClass>
                                        </Label>
                                    </children>
                                    <padding><Insets top="6.0" bottom="6.0" left="10.0" right="10.0" /></padding>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="6.0" styleClass="tag-toggle-card">
                                    <children>
                                        <RadioButton fx:id="explicitContentRadio" mnemonicParsing="false" text="Esplicita" />
                                        <Label fx:id="explicitPreview" text="E" visible="false" managed="false">
                                            <styleClass><String fx:value="tag-badge" /><String fx:value="tag-explicit" /></styleClass>
                                        </Label>
                                    </children>
                                    <padding><Insets top="6.0" bottom="6.0" left="10.0" right="10.0" /></padding>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="6.0" styleClass="tag-toggle-card">
                                    <children>
                                        <RadioButton fx:id="newReleaseRadio" mnemonicParsing="false" text="Nuova uscita" />
                                        <Label fx:id="newReleasePreview" text="NEW" visible="false" managed="false">
                                            <styleClass><String fx:value="tag-badge" /><String fx:value="tag-new-release" /></styleClass>
                                        </Label>
                                    </children>
                                    <padding><Insets top="6.0" bottom="6.0" left="10.0" right="10.0" /></padding>
                                </HBox>
                            </children>
                        </HBox>
                        <Label text="Tag Personali" styleClass="tag-section-title">
                            <VBox.margin><Insets top="10.0" /></VBox.margin>
                        </Label>
                        <javafx.scene.layout.FlowPane fx:id="personalTagsPane" hgap="10.0" vgap="10.0" />
                    </children>
                </VBox>
                <HBox alignment="CENTER_RIGHT" spacing="10.0" VBox.vgrow="ALWAYS">
                    <children>
                        <Button fx:id="addTrackButton" mnemonicParsing="false" onAction="#addTrack" text="✓  Conferma" />
                        <Button fx:id="saveButton" mnemonicParsing="false" onAction="#saveChanges" text="Salva Modifiche" visible="false" />
                        <Button fx:id="editButton" mnemonicParsing="false" onAction="#editTrack" text="✎  Modifica" visible="false" />
                        <Button fx:id="cancelButton" mnemonicParsing="false" onAction="#cancelChanges" styleClass="cancel-button" text="✕  Annulla" visible="false" />
                        <Button fx:id="buttonBack" mnemonicParsing="false" onAction="#goBack" styleClass="cancel-button" text="✕  Annulla" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
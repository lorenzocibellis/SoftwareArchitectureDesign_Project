<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="350.0" prefWidth="350.0" spacing="10.0" stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.unisa.musicplaylistmanager.tag.TagManagerController">
    <padding>
        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
    </padding>
    <children>
        <Label text="I tuoi tag personali" textFill="#555555">
            <font>
                <Font name="System Bold" size="16.0" />
            </font>
        </Label>
        <ListView fx:id="tagsList" prefHeight="200.0" VBox.vgrow="ALWAYS" />
        <HBox spacing="10.0" alignment="CENTER_LEFT">
            <children>
                <TextField fx:id="newTagField" promptText="Nome del nuovo tag..." HBox.hgrow="ALWAYS" />
                <Button fx:id="addButton" mnemonicParsing="false" onAction="#addTag" text="Aggiungi" />
            </children>
        </HBox>
        <HBox alignment="CENTER_RIGHT">
            <children>
                <Button mnemonicParsing="false" onAction="#closeWindow" text="Chiudi" styleClass="cancel-button" />
            </children>
            <VBox.margin>
                <Insets top="10.0" />
            </VBox.margin>
        </HBox>
    </children>
</VBox>
